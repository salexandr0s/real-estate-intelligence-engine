# =============================================================================
# ImmoRadar — Production Environment
# =============================================================================
# Copy this file to .env and replace all CHANGEME values before starting.
# Generate secrets with: openssl rand -hex 32
# =============================================================================

# --- Application ---
NODE_ENV=production
LOG_LEVEL=info

# --- API ---
API_PORT=8080
API_BEARER_TOKEN=CHANGEME_GENERATE_WITH_openssl_rand_hex_32
API_DOCS_PUBLIC=false

# --- Database ---
DATABASE_URL=postgres://immoradar:CHANGEME@postgres:5432/immoradar?sslmode=require
POSTGRES_USER=immoradar
POSTGRES_PASSWORD=CHANGEME
POSTGRES_DB=immoradar

# --- Redis ---
REDIS_URL=redis://:CHANGEME@redis:6379

# --- Object Storage (MinIO) ---
S3_ENDPOINT=http://minio:9000
S3_BUCKET=immoradar
S3_ACCESS_KEY=CHANGEME
S3_SECRET_KEY=CHANGEME
MINIO_ROOT_USER=CHANGEME
MINIO_ROOT_PASSWORD=CHANGEME

# --- Workers ---
SCHEDULER_ENABLED=true
FEATURE_GEOCODING_ENABLED=true

# --- Monitoring (optional, used by docker-compose.monitoring.yml) ---
GF_SECURITY_ADMIN_PASSWORD=admin
