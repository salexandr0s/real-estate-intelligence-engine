{
  "name": "@immoradar/db",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "dependencies": {
    "pg": "^8.13.1",
    "@immoradar/config": "*",
    "@immoradar/contracts": "*",
    "@immoradar/observability": "*"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "migrate": "tsx src/migrate.ts",
    "seed": "tsx seeds/seed.ts",
    "lint": "eslint src/",
    "test": "npm run test:unit",
    "test:unit": "vitest run --root ../.. --passWithNoTests packages/db/src/**/*.test.ts",
    "test:integration": "vitest run --root ../.. --config vitest.config.integration.ts tests/integration/migrations.test.ts tests/integration/migration-rollback.test.ts tests/integration/mailbox-outreach-migrations.test.ts",
    "clean": "rm -rf dist"
  }
}
