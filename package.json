{
  "name": "real-estate-intelligence-engine",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@10.9.4",
  "description": "Always-on real estate intelligence platform for Austrian property investment",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:integration": "vitest run --config vitest.config.integration.ts",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "db:migrate": "npm -w packages/db run migrate",
    "db:seed": "npm -w packages/db run seed",
    "clean": "turbo run clean",
    "verify": "npm run lint && npm run typecheck && npm run test:unit",
    "scrape": "npx tsx scripts/scrape-and-ingest.ts",
    "rescore": "npx tsx scripts/rescore-listings.ts",
    "replay:normalize": "npx tsx scripts/replay-normalization.ts",
    "replay:scores": "npx tsx scripts/rescore-listings.ts",
    "reparse": "npx tsx scripts/reparse-raw.ts",
    "backfill": "npx tsx scripts/backfill-source.ts",
    "report:quality": "npx tsx scripts/data-quality-report.ts",
    "baselines": "npx tsx scripts/compute-baselines.ts",
    "canary": "npx tsx scripts/canary-crawl.ts",
    "generate:types": "bash scripts/generate-types.sh",
    "load-test": "npx tsx scripts/load-test-search.ts",
    "import:buildings": "npx tsx scripts/import-building-facts.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
