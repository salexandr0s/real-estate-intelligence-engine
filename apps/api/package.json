{
  "name": "@immoradar/api",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@immoradar/config": "*",
    "@immoradar/contracts": "*",
    "@immoradar/analysis": "*",
    "@immoradar/db": "*",
    "@immoradar/legal-rent": "*",
    "@immoradar/copilot": "*",
    "@immoradar/observability": "*",
    "@immoradar/outreach": "*",
    "fastify": "^5.8.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "tsx": "^4.19.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "npm run test:unit",
    "test:unit": "vitest run --root ../.. --passWithNoTests apps/api/src/**/*.test.ts",
    "test:integration": "vitest run --root ../.. --config vitest.config.integration.ts tests/integration/outreach-api.test.ts",
    "clean": "rm -rf dist"
  }
}
