
# example.env
# Copy to .env.local or .env.production and fill with real values.

NODE_ENV=development
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8080
API_BASE_URL=http://localhost:8080
API_AUTH_MODE=single_user_token
API_BEARER_TOKEN=replace_me
API_TRUST_PROXY=false
API_DOCS_PUBLIC=true
# Production-only emergency override. Leave false unless you explicitly want
# bearer-less docs in production and have network controls in place.
API_DOCS_PUBLIC_PRODUCTION_OVERRIDE=false

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://postgres:postgres@localhost:5432/immoradar
DATABASE_POOL_MAX=20
DATABASE_STATEMENT_TIMEOUT_MS=10000

# -----------------------------------------------------------------------------
# Redis / BullMQ
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
BULLMQ_PREFIX=immoradar

# -----------------------------------------------------------------------------
# Object storage (S3-compatible / MinIO)
# -----------------------------------------------------------------------------
S3_ENDPOINT=http://localhost:9000
S3_REGION=eu-central-1
S3_BUCKET=immoradar
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# -----------------------------------------------------------------------------
# Playwright / browser runtime
# -----------------------------------------------------------------------------
PLAYWRIGHT_BROWSER=chromium
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_DEFAULT_TIMEOUT_MS=30000
PLAYWRIGHT_NAVIGATION_TIMEOUT_MS=45000
PLAYWRIGHT_LOCALE=de-AT
PLAYWRIGHT_TIMEZONE_ID=Europe/Vienna
PLAYWRIGHT_MAX_CONTEXTS_PER_WORKER=2
PLAYWRIGHT_CAPTURE_SCREENSHOT_ON_FAILURE=true
PLAYWRIGHT_CAPTURE_HTML_ON_FAILURE=true
PLAYWRIGHT_CAPTURE_HAR_ON_FAILURE=false
SCRAPER_BROWSER_RUNTIME=playwright
SCRAPER_PATCHRIGHT_SOURCES=

# -----------------------------------------------------------------------------
# Documents / outbound download policy
# -----------------------------------------------------------------------------
DOCUMENT_DOWNLOAD_TIMEOUT_MS=20000
DOCUMENT_MAX_BYTES=25000000

# -----------------------------------------------------------------------------
# Scraper behavior
# -----------------------------------------------------------------------------
SCRAPER_DEFAULT_RATE_LIMIT_RPM=12
SCRAPER_DEFAULT_CONCURRENCY_PER_SOURCE=1
SCRAPER_COOLDOWN_AFTER_BLOCK_MS=900000
SCRAPER_JITTER_MIN_MS=2000
SCRAPER_JITTER_MAX_MS=7000
SCRAPER_CANARY_ENABLED=true

# -----------------------------------------------------------------------------
# Scheduler / cadence
# -----------------------------------------------------------------------------
# Bundled macOS releases switch this automatically between `setup` and `active`.
IMMORADAR_RUNTIME_BOOT_MODE=active
SCHEDULER_ENABLED=true
SCHEDULER_LOOP_INTERVAL_MS=30000
BASELINE_RECALC_CRON=0 * * * *
SOURCE_HEALTH_RECALC_CRON=*/10 * * * *

# -----------------------------------------------------------------------------
# Alerts
# -----------------------------------------------------------------------------
ALERTS_EMAIL_ENABLED=false
ALERTS_FROM_EMAIL=alerts@example.com
ALERTS_SMTP_HOST=localhost
ALERTS_SMTP_PORT=1025
ALERTS_SMTP_SECURE=false
ALERTS_SMTP_USER=
ALERTS_SMTP_PASSWORD=
ALERTS_WEBHOOK_ENABLED=false
ALERTS_WEBHOOK_TIMEOUT_MS=5000

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
PROMETHEUS_ENABLED=true
METRICS_TOKEN=replace_with_separate_metrics_token
SENTRY_DSN=

# -----------------------------------------------------------------------------
# App / single-user bootstrap
# -----------------------------------------------------------------------------
DEFAULT_USER_EMAIL=owner@example.com
DEFAULT_USER_DISPLAY_NAME=Owner
DEFAULT_USER_TIMEZONE=Europe/Vienna

# -----------------------------------------------------------------------------
# Feature flags
# -----------------------------------------------------------------------------
FEATURE_GEOCODING_ENABLED=false
FEATURE_CROSS_SOURCE_CLUSTERING_ENABLED=false
FEATURE_EMAIL_ALERTS_ENABLED=false
FEATURE_WEBHOOK_ALERTS_ENABLED=false
